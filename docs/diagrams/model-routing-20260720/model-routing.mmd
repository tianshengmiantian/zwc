    classDef model fill:#E8F5E9,stroke:#3E7C59,color:#111827,stroke-width:2px;
    classDef tool fill:#FFF8E1,stroke:#A67C00,color:#111827,stroke-width:1.6px;
    classDef storage fill:#F3EAF7,stroke:#765083,color:#111827,stroke-width:1.6px;

    class U,W,SEND entry;
    class A,P,C,V,CFG process;
